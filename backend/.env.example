# Copy this file to .env and fill in your values

# HuggingFace API token (get free at https://huggingface.co/settings/tokens)
HF_API_TOKEN=hf_your_token_here

# Advanced model to use via HF Inference API
# Free options: Salesforce/blip2-opt-2.7b
# Better (needs Pro): llava-hf/llava-v1.6-mistral-7b-hf
HF_MODEL_ID=Salesforce/blip2-opt-2.7b

# Local model (runs on your RTX 3050 — no token needed)
LOCAL_MODEL_ID=Salesforce/blip-vqa-base

# Max image size in pixels (keep at 480 for 4GB VRAM)
MAX_IMAGE_SIZE=480
